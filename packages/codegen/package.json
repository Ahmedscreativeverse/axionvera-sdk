{
  "name": "@axionvera/codegen",
  "version": "1.0.0",
  "description": "Soroban WASM spec parser and TypeScript contract-client code generator for the Axionvera SDK.",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && npx tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "sideEffects": false,
  "dependencies": {
    "@stellar/stellar-sdk": "^14.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.57.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.6",
    "typescript": "^5.5.4"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
