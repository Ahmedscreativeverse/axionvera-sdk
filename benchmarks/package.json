{
  "name": "@axionvera/benchmarks",
  "version": "0.2.0",
  "description": "Performance benchmarking framework for Axionvera SDK — measures contract interactions, serialization, transaction creation, and network communication",
  "private": true,
  "scripts": {
    "benchmark": "npx ts-node index.ts",
    "benchmark:ci": "npx ts-node index.ts --ci --json",
    "benchmark:html": "npx ts-node index.ts --html --json",
    "benchmark:save-baseline": "npx ts-node index.ts --save-baseline --json",
    "benchmark:contract": "npx ts-node index.ts --category=contract",
    "benchmark:serialization": "npx ts-node index.ts --category=serialization",
    "benchmark:transaction": "npx ts-node index.ts --category=transaction",
    "benchmark:network": "npx ts-node index.ts --category=network",
    "benchmark:legacy": "node xdr-parsing.benchmark.js"
  },
  "dependencies": {
    "@axionvera/core": "file:../packages/core",
    "@stellar/stellar-sdk": "^14.6.1"
  },
  "devDependencies": {
    "benchmark": "^2.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
